# Supabase (from your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Anthropic model IDs. Defaults below are reasonable current Anthropic models;
# change when Anthropic releases newer ones.
ANTHROPIC_MODEL_PROSE=claude-sonnet-4-5
ANTHROPIC_MODEL_QUICK=claude-haiku-4-5

# Voyage AI — embeddings for scene RAG (Phase 2). Optional; RAG skips if unset.
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3

# Auth allowlist — comma-separated emails allowed to sign in to the app.
# Her email is the primary user. Paul's email is admin-only.
APP_ALLOWED_EMAILS=
APP_ADMIN_EMAILS=

# Which product this Vercel deploy is (server-only; not exposed to the browser).
# Scopes new `projects` rows and AI system prompts. Comma of valid values in
# `lib/deployment/writing-profile.ts` (e.g. pnr_dawn, erotic_mature). Unset = pnr_dawn (local).
# Use different values + disjoint APP_ALLOWED_EMAILS per deploy to keep slices isolated.
# WRITING_PROFILE=pnr_dawn

# Canonical app origin (magic-link redirects + metadata). Local: localhost.
# On Vercel use this deployment’s URL (e.g. https://your-app.vercel.app) and
# add the same origin + /auth/callback under Supabase → Auth → Redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: public share base URL for reader mode (defaults to NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_SHARE_BASE_URL=
